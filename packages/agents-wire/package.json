{
  "name": "@pivanov/agents-wire",
  "version": "0.1.0",
  "description": "One TypeScript SDK for every local coding agent. ACP transport, Vercel AI SDK provider, cost budgets, structured JSON, multi-agent orchestration.",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22",
    "bun": ">=1.0"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "import": "./dist/errors.mjs",
      "require": "./dist/errors.cjs"
    },
    "./ai-sdk": {
      "types": "./dist/ai-sdk/index.d.ts",
      "import": "./dist/ai-sdk/index.mjs",
      "require": "./dist/ai-sdk/index.cjs"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.mjs",
      "require": "./dist/testing/index.cjs"
    },
    "./catalog": {
      "types": "./dist/catalog/index.d.ts",
      "import": "./dist/catalog/index.mjs",
      "require": "./dist/catalog/index.cjs"
    },
    "./orchestrate": {
      "types": "./dist/orchestrate/index.d.ts",
      "import": "./dist/orchestrate/index.mjs",
      "require": "./dist/orchestrate/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "agents-wire": "./dist/cli.mjs"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "license": "MIT",
  "author": "Pavel Ivanov <iweb.ivanov@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/pivanov/agents-wire",
    "directory": "packages/agents-wire"
  },
  "homepage": "https://github.com/pivanov/agents-wire",
  "bugs": {
    "url": "https://github.com/pivanov/agents-wire/issues"
  },
  "keywords": [
    "agent",
    "agents",
    "acp",
    "agent-client-protocol",
    "claude",
    "claude-code",
    "codex",
    "cursor",
    "copilot",
    "gemini",
    "opencode",
    "droid",
    "ai-sdk",
    "vercel-ai-sdk",
    "sdk",
    "typescript",
    "streaming",
    "tool-use",
    "structured-output",
    "json-schema"
  ],
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json --emitDeclarationOnly && chmod +x dist/cli.cjs dist/cli.mjs",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "knip": "knip-bun",
    "prepublishOnly": "cp ../../README.md ./README.md && bun run build"
  },
  "dependencies": {
    "@agentclientprotocol/claude-agent-acp": "^0.32.0",
    "@agentclientprotocol/sdk": "^0.21.0",
    "@ai-sdk/provider": "^3.0.10",
    "@pivanov/claude-wire": "^0.2.0",
    "@zed-industries/codex-acp": "^0.13.0",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "@types/node": ">=22",
    "ai": "^6.0.0"
  },
  "peerDependenciesMeta": {
    "@types/node": {
      "optional": true
    },
    "ai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/node": "^22.10.5",
    "knip": "^6.11.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
