{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "src",
    "noEmit": false,
    "declarationMap": false,
    "sourceMap": false,
    "module": "ESNext",
    "target": "ES2023"
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "tests"],
  "tsc-alias": {
    "resolveFullPaths": true,
    "verbose": false
  }
}
